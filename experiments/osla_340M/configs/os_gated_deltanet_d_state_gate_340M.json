    "use_osgm": true,
    "osgm_eta": 1.0,
    "osgm_use_denominator": false,
    "osgm_d_min": 0.0,
    "osgm_d_max": 1e9,
    "osgm_decay_mode": "data_dependent",
    "osgm_d_decay_source": "gdn"
